# Backend API URL (optional in dev – Vite proxies /api to http://localhost:3000)
# Production: set to your backend URL, e.g. https://ai-estimatic-tvyg.vercel.app
VITE_API_URL=

# Gemini API Key – required for AI pricing and ChatBot. In Vercel: add this in
# Project → Settings → Environment Variables for the frontend project.
GEMINI_API_KEY=
